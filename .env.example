# ── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/albero
# Docker:  mongodb://mongo:27017/albero
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/albero
MONGODB_URI=mongodb://mongo:27017/albero

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Dev (NODE_ENV != production): generic SMTP, e.g. Mailtrap. MAIL_HOST/PORT/SECURE
# are only read in this mode.
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_password
MAIL_FROM=noreply@albero.app

# Production (NODE_ENV=production): sends via Gmail SMTP instead (MAIL_HOST/
# PORT/SECURE are ignored). MAIL_USER must be a full @gmail.com address, and
# MAIL_PASS must be a Google App Password — NOT the account's login password:
#   1. Enable 2-Step Verification on the Gmail account.
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Set MAIL_USER=that-address@gmail.com and MAIL_PASS=<the 16-char app password>
# MAIL_FROM should match MAIL_USER (Gmail rejects/overrides mismatched From addresses).

# ── Frontend URL (used in verification email link) ────────────────────────────
WEB_URL=http://localhost:4200
