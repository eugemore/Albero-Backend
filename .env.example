# ── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/albero
# Docker:  mongodb://mongo:27017/albero
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/albero
MONGODB_URI=mongodb://mongo:27017/albero

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Example: Mailtrap for dev, SendGrid / SES for production
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_password
MAIL_FROM=noreply@albero.app

# ── Frontend URL (used in verification email link) ────────────────────────────
WEB_URL=http://localhost:4200
